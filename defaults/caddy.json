{
    "admin": {
      "listen": "0.0.0.0:2019"
    },
    "apps": {
      "http": {
        "servers": {
          "net": {
            "listen": [":80"],
            "routes": [
              {
                "match": [{ "path": ["/api/*"] }],
                "handle": [
                  {
                    "handler": "reverse_proxy",
                    "upstreams": [{ "dial": "api:3000" }]
                  }
                ]
              },
              {
                "match": [{ "path": ["/*"] }],
                "handle": [
                  {
                    "handler": "reverse_proxy",
                    "upstreams": [{ "dial": "ui:4173" }]
                  }
                ]
              }
            ]
          }
        }
      }
    }
  }