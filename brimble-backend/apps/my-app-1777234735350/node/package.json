{
  "name": "SMOOTH-BALLOT-BE",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.591.0",
    "@aws-sdk/s3-request-presigner": "^3.591.0",
    "@grpc/grpc-js": "^1.11.1"
  },
  "devDependencies": {
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "@modules/(.*)$": "<rootDir>/src/modules/$1",
      "@db/(.*)$": "<rootDir>/src/db/$1",
      "@utils/(.*)$": "<rootDir>/src/utils/$1",
      "@env/(.*)$": "<rootDir>/src/environment/$1",
      "@cache/(.*)$": "<rootDir>/src/cache/$1",
      "@validators/(.*)$": "<rootDir>/src/validators/$1",
      "@decorators/(.*)$": "<rootDir>/src/decorators/$1",
      "src/(.*)$": "<rootDir>/src/$1",
      "src/super-admin/protos/(.*)": "<rootDir>/src/super-admin/protos/$1"
    }
  }
}
